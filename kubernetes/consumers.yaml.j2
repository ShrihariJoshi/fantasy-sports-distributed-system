apiVersion: apps/v1
kind: Deployment
metadata:
  name: player-consumer
spec:
  replicas: 1
  selector:
    matchLabels:
      app: player-consumer
  template:
    metadata:
      labels:
        app: player-consumer
    spec:
      containers:
        - name: consumer
          image: fantasysportsacr.azurecr.io/fantasy-consumers:latest
          command: ["python", "consumers/player_consumer.py"]
          env:
            - name: MONGO_URI
              value: "{{ mongo_connection_uri }}"
---
